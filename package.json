{
  "name": "music-memo-machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "dev:lan": "concurrently -k -n api,web -c cyan,green \"HOST=0.0.0.0 node server/index.js\" \"vite --host 0.0.0.0\"",
    "build": "tsc -b && vite build",
    "preview": "NODE_ENV=production node server/index.js",
    "seed": "node scripts/seed-fixtures.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18"
  }
}
