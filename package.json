{
  "name": "music-memo-machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist coverage .vite .eslintcache *.tsbuildinfo",
    "dev": "concurrently -k -n api,web -c cyan,green \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "dev:lan": "concurrently -k -n api,web -c cyan,green \"HOST=0.0.0.0 node server/index.js\" \"vite --host 0.0.0.0\"",
    "build": "tsc -b && vite build",
    "verify": "npm run lint && npm run test && npm run build",
    "verify:push": "npm run verify",
    "prepare": "simple-git-hooks",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "NODE_ENV=production node server/index.js",
    "reset": "node scripts/seed-fixtures.mjs",
    "seed": "node scripts/seed-fixtures.mjs",
    "emulator:cli": "node scripts/recorder-emulator.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run verify:push"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@taylorvance/tv-shared-web": "^0.7.1",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@taylorvance/tv-shared-dev": "^0.1.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  }
}
